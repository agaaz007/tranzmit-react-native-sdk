{
  "name": "tranzmit-react-native-sdk",
  "private": true,
  "version": "0.1.1",
  "description": "Standalone React Native SDK for Tranzmit server-driven WebView paywalls.",
  "workspaces": [
    "packages/shared",
    "packages/react-native"
  ],
  "scripts": {
    "build": "tsc -b --force packages/shared packages/react-native",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "preview": "tsc -b --force packages/shared packages/react-native && node templates/preview/build-preview.mjs"
  },
  "devDependencies": {
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^22.0.0",
    "@types/react": "^18.3.28",
    "@types/react-dom": "^18.3.7",
    "jsdom": "^24.1.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  }
}
